# URL do NossoCRM do cliente (sem barra final)
NOSSOCRM_URL=https://nossocrm-cliente.vercel.app

# API Key gerada em: NossoCRM → Configurações → API
NOSSOCRM_API_KEY=vai_sk_xxxxxxxxxxxxxxxxxxxx

# Chave do board (ver em: NossoCRM → Boards → editar board → campo "key")
BOARD_KEY=odonto

# Nome exato da coluna destino (copiar do board, sem emoji)
STAGE_LABEL=Consulta Agendada

# Segredo para validar que o webhook veio do GPTMaker (opcional mas recomendado)
WEBHOOK_SECRET=
